NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Failure simulation (dev/demo only — omit or set to false in production)
# ENABLE_FAILURE_SIMULATION — master switch; default: false (omit to disable)
# FAILURE_RATE             — float 0–1, probability of injected failure; default: 0.3
# LATENCY_MIN_MS           — minimum artificial delay per operation (ms); default: 200
# LATENCY_MAX_MS           — maximum artificial delay per operation (ms); default: 800
ENABLE_FAILURE_SIMULATION=true
FAILURE_RATE=0.3
LATENCY_MIN_MS=200
LATENCY_MAX_MS=800
